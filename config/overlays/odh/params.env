trustyaiServiceImage=quay.io/opendatahub/trustyai-service:odh-3.5-ea1
trustyaiOperatorImage=quay.io/opendatahub/trustyai-service-operator:odh-3.5-ea1
evalHubImage=quay.io/opendatahub/odh-eval-hub:odh-3.5-ea1
kube-rbac-proxy=quay.io/openshift/origin-kube-rbac-proxy:4.19
kServeServerless=enabled
lmes-driver-image=quay.io/opendatahub/ta-lmes-driver:odh-3.5-ea1
lmes-pod-image=quay.io/opendatahub/ta-lmes-job:odh-3.5-ea1
lmes-pod-checking-interval=10s
lmes-image-pull-policy=Always
lmes-max-batch-size=24
lmes-default-batch-size=8
lmes-detect-device=true
lmes-allow-online=true
lmes-allow-code-execution=true
guardrails-orchestrator-image=quay.io/opendatahub/ta-guardrails-orchestrator:odh-2.35
guardrails-built-in-detector-image=quay.io/opendatahub/odh-built-in-detector:odh-3.5-ea1
guardrails-sidecar-gateway-image=quay.io/opendatahub/vllm-orchestrator-gateway:odh-3.5-ea1
ragas-provider-image=quay.io/opendatahub/llama-stack-provider-ragas:odh-3.5-ea1
garak-provider-image=quay.io/trustyai/llama-stack-provider-trustyai-garak:odh-3.5-ea1
nemo-guardrails-image=quay.io/trustyai/nemo-guardrails-server:latest
evalhub-provider-guidellm-image=quay.io/evalhub/community-guidellm:v0.2.0
evalhub-provider-lighteval-image=quay.io/evalhub/community-lighteval:v0.2.0
evalhub-provider-ibm-clear-image=quay.io/evalhub/community-ibm-clear:v0.2.0